---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import { slugifyStr } from "@/utils/slugify";

export async function getStaticPaths() {
  const episodes = await getCollection("podcast");
  return episodes.map((ep) => ({
    params: { slug: ep.id },
    props: { episode: ep.data, content: ep.body },
  }));
}

const { episode, content } = Astro.props;

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout title={`${episode.title} · 链周志播客 · weekly.jask.dev`}>
  <Header />
  <main id="main-content" class="mx-auto max-w-3xl px-5">
    <BackButton href="/podcast/" text="播客" />
    <article class="podcast-detail">
      <p class="episode-num">EP {String(episode.episode).padStart(3, "0")} · S{episode.season}</p>
      <h1 transition:name={slugifyStr(episode.title)} class="text-2xl font-bold sm:text-3xl mb-2">{episode.title}</h1>
      <p class="episode-date">{formatDate(episode.pubDatetime)} · {episode.duration}</p>

      <div class="episode-player-wrap">
        <audio id="podcast-audio" controls preload="metadata" src={episode.audioUrl}></audio>
      </div>

      {episode.transcriptUrl && (
        <div id="transcript-scroll" class="transcript-scroll" data-transcript-url={episode.transcriptUrl}></div>
      )}

      <div class="episode-desc-text" set:html={content}></div>

      {episode.articleSlug && (
        <a href={`/posts/${episode.articleSlug}/`} class="episode-source-link">
          ← 阅读原文
        </a>
      )}
    </article>
  </main>
  <Footer />
</Layout>

<style is:global>
  .podcast-detail { padding: 1.5rem 0 3rem; }
  .episode-num {
    font-family: var(--font-mono, monospace);
    font-size: 0.8rem; font-weight: 700;
    color: var(--accent, hsl(228 80% 60%));
    letter-spacing: 0.05em; margin-bottom: 0.5rem;
  }
  .episode-date { font-size: 0.85rem; opacity: 0.55; margin-bottom: 1.5rem; }
  .episode-player-wrap { margin-bottom: 1rem; }
  .episode-player-wrap audio { width: 100%; }
  [data-theme="dark"] audio { filter: invert(0.92) hue-rotate(180deg); }

  /* ── Lyrics / transcript scroll ── */
  .transcript-scroll {
    max-height: 500px;
    overflow-y: auto;
    padding: 2rem 0;
    margin-bottom: 2rem;
    scroll-behavior: smooth;
    mask-image: linear-gradient(to bottom,
      transparent 0%, hsl(0 0% 0%) 12%, hsl(0 0% 0%) 88%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom,
      transparent 0%, hsl(0 0% 0%) 12%, hsl(0 0% 0%) 88%, transparent 100%);
    scrollbar-width: none;
  }
  .transcript-scroll::-webkit-scrollbar { display: none; }

  .lyric-line {
    padding: 0.55rem 0;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.35;
    font-size: 0.95rem;
    line-height: 1.65;
    transform-origin: left center;
    will-change: opacity, transform, filter;
  }
  .lyric-line:hover { opacity: 0.6; }

  .lyric-line.active {
    opacity: 1;
    font-size: 1.15rem;
    font-weight: 600;
    filter: none;
  }
  .lyric-line.near {
    opacity: 0.6;
  }

  .lyric-speaker {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    margin-right: 0.6rem;
    vertical-align: middle;
    transition: all 0.4s ease;
  }
  .lyric-speaker.male { background: hsl(210 60% 55%); }
  .lyric-speaker.female { background: hsl(330 60% 60%); }
  .lyric-line.active .lyric-speaker { width: 8px; height: 8px; }

  .episode-desc-text { font-size: 0.9rem; line-height: 1.75; opacity: 0.85; }
  .episode-desc-text p { margin-bottom: 1rem; }
  .episode-desc-text h2 { font-size: 1.05rem; font-weight: 600; margin: 1.5rem 0 0.75rem; }
  .episode-desc-text ul { padding-left: 1.2rem; margin-bottom: 1rem; }
  .episode-desc-text li { margin-bottom: 0.3rem; }
  .episode-source-link {
    display: inline-block; margin-top: 1.5rem;
    font-size: 0.85rem; color: var(--accent, hsl(228 80% 60%));
    text-decoration: none; padding: 0.5rem 1rem;
    border-radius: 999px; background: hsl(0 0% 96%);
  }
  .episode-source-link:hover { background: hsl(0 0% 93%); }
  [data-theme="dark"] .episode-source-link { background: hsl(228 14% 13%); }
  [data-theme="dark"] .episode-source-link:hover { background: hsl(228 14% 17%); }
</style>

<script>
  function initTranscript() {
    const audio = document.getElementById('podcast-audio');
    const container = document.getElementById('transcript-scroll');
    if (!audio || !container) return;

    const url = container.dataset.transcriptUrl;
    if (!url) return;

    let rounds = [];
    let lineEls = [];

    // Add top/bottom padding spacers for mask effect
    const spacerTop = document.createElement('div');
    spacerTop.style.height = '180px';
    const spacerBottom = document.createElement('div');
    spacerBottom.style.height = '180px';

    fetch(url)
      .then(r => r.json())
      .then(data => {
        rounds = data.rounds || [];
        container.appendChild(spacerTop);

        rounds.forEach((round, i) => {
          const isMale = round.speaker.includes('male');
          const div = document.createElement('div');
          div.className = 'lyric-line';
          div.dataset.index = i;
          div.innerHTML =
            '<span class="lyric-speaker ' + (isMale ? 'male' : 'female') + '"></span>' +
            '<span class="lyric-text">' + round.text + '</span>';
          div.addEventListener('click', () => {
            audio.currentTime = round.start_time;
            if (audio.paused) audio.play();
          });
          container.appendChild(div);
          lineEls.push(div);
        });

        container.appendChild(spacerBottom);
      })
      .catch(() => {});

    // Sticky player shadow on scroll — removed, causes layout issues
    /* removed */

    // Highlight + auto-scroll
    audio.addEventListener('timeupdate', () => {
      if (rounds.length === 0) return;
      const t = audio.currentTime;

      let activeIdx = -1;
      for (let i = 0; i < rounds.length; i++) {
        if (rounds[i].start_time <= t) activeIdx = i;
        else break;
      }

      lineEls.forEach((el, i) => {
        el.classList.remove('active', 'near');
        if (i === activeIdx) {
          el.classList.add('active');
        } else if (Math.abs(i - activeIdx) === 1) {
          el.classList.add('near');
        }
      });

      // Smooth scroll active line to center
      if (activeIdx >= 0 && lineEls[activeIdx]) {
        const el = lineEls[activeIdx];
        const target = el.offsetTop - container.clientHeight / 2 + el.clientHeight / 2;
        container.scrollTo({ top: target, behavior: 'smooth' });
      }
    });
  }

  initTranscript();
  document.addEventListener('astro:after-swap', initTranscript);
</script>
