---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const deepDivePosts = sortedPosts.filter(({ data }) => data.series === "深潜");
const weeklyPosts = sortedPosts.filter(({ data }) => data.series !== "深潜");
const featuredWeekly = weeklyPosts.filter(({ data }) => data.featured);
const recentWeekly = weeklyPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-8 pb-6 text-center">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        链周志
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS 订阅"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
最平实的语言, 记录对区块链技术的认知历程, 欢迎订阅链周志
      </p>
      <p class="mt-2">
        更多内容请返回
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="https://jask.dev"
        >
          主页
        </LinkButton>
      </p>

      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex flex-col items-center sm:flex-row sm:items-center sm:justify-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">社交媒体:</div>
            <Socials />
          </div>
        )
      }
    </section>

<!-- JSON-LD: link author to jask.dev Person entity -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "链周志",
  "alternateName": "LinkLog",
  "url": "https://weekly.jask.dev",
  "inLanguage": "zh-CN",
  "author": {
    "@type": "Person",
    "name": "Jask",
    "url": "https://jask.dev",
    "sameAs": ["https://x.com/jask_don", "https://github.com/respectevery01"]
  },
  "publisher": {
    "@type": "Person",
    "name": "Jask",
    "url": "https://jask.dev"
  }
})} />

    <Hr />

    {
      featuredPosts.length > 0 && (
        <section id="featured" class="pt-8 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">热榜</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      deepDivePosts.length > 0 && (
        <section id="deep-dive" class="pt-8 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">深潜</h2>
          <p class="text-sm opacity-60 mt-1 mb-4">长文深度拆解，一刀切开看里面</p>
          <ul>
            {deepDivePosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      weeklyPosts.length > 0 && (
        <section id="weekly" class="pt-8 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">周报</h2>
          <p class="text-sm opacity-60 mt-1 mb-4">每周一条 Web3 快评</p>
          <ul>
            {weeklyPosts.slice(0, SITE.postPerIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        查看全部
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
